MONGO_URI=mongodb://127.0.0.1:27017/bps_event_portal
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
PORT=5001
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173

# Optional production upload storage.
# If these are set, uploads go to Cloudinary instead of local disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=bps-event-portal
